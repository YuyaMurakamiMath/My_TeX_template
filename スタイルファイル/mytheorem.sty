% --------------------------------------------------------------------------
%		cleverefパッケージ
% --------------------------------------------------------------------------

\usepackage[noabbrev,nameinlink,capitalize]{cleveref} % amsmath → hyperref → cleveref → autonum の順で読み込む
% 参照した数式だけに番号を振るautonumパッケージ. *付き数式環境は使えない. 
\let\etoolboxforlistloop\forlistloop % save the good meaning of \forlistloop
\usepackage{autonum} 
\let\forlistloop\etoolboxforlistloop % restore the good meaning of \forlistloop

\newcommand{\crefrangeconjunction}{--} % 3 つ以上連番で参照するときの表記を設定
\newcommand{\crefrangepreconjunction}{}
\newcommand{\crefrangepostconjunction}{}
\newcommand{\crefpairconjunction}{, }
\newcommand{\crefmiddleconjunction}{, }
\newcommand{\creflastconjunction}{, }
\newcommand{\crefpairgroupconjunction}{, }
\newcommand{\crefmiddlegroupconjunction}{, }
\newcommand{\creflastgroupconjunction}{, }

% --------------------------------------------------------------------------
%		数式
% --------------------------------------------------------------------------

\crefname{equation}{式}{式}                % 数式参照時の表記を設定

% --------------------------------------------------------------------------
%		図表
% --------------------------------------------------------------------------

\crefname{figure}{図}{図}
\crefname{subfigure}{図}{図}
\crefname{table}{表}{表}
\crefname{subtable}{表}{表}

% --------------------------------------------------------------------------
%		節番号など
% --------------------------------------------------------------------------

\crefname{part}{}{}
\creflabelformat{part}{#2#1部#3}
\crefname{chapter}{}{}
\creflabelformat{chapter}{#2#1章#3}
\crefname{section}{}{}
\creflabelformat{section}{#2#1節#3}
\crefname{subsection}{}{}
\creflabelformat{subsection}{#2#1項#3}

\crefname{appendix}{補遺}{補遺}

%\cref{item:hogehoge}で参照
\crefname{enumi}{}{}
\crefname{enumii}{}{}
\crefname{enumiii}{}{}
\crefname{enumiiii}{}{}

% --------------------------------------------------------------------------
%		定理環境
% --------------------------------------------------------------------------

\theoremstyle{definition} %Theorem 環境の見出しを太字、本文に斜体を使わない

\newaliascnt{dfn}{theoremcounter}
\newtheorem{dfn}[dfn]{定義}
\aliascntresetthe{dfn}
\crefname{dfn}{定義}{定義} % dfn環境参照時の表記を設定

\newaliascnt{thm}{theoremcounter}
\newtheorem{thm}[thm]{定理}
\aliascntresetthe{thm}
\crefname{thm}{定理}{定理}

\newaliascnt{lem}{theoremcounter}
\newtheorem{lem}[lem]{補題}
\aliascntresetthe{lem}
\crefname{lem}{補題}{補題}

\newaliascnt{prop}{theoremcounter}
\newtheorem{prop}[prop]{命題}
\aliascntresetthe{prop}
\crefname{prop}{命題}{命題}

\newaliascnt{cor}{theoremcounter}
\newtheorem{cor}[cor]{系}
\aliascntresetthe{cor}
\crefname{cor}{系}{系}

\newaliascnt{rem}{theoremcounter}
\newtheorem{rem}[rem]{注意}
\aliascntresetthe{rem}
\crefname{rem}{注意}{注意}

\newaliascnt{ex}{theoremcounter}
\newtheorem{ex}[ex]{例}
\aliascntresetthe{ex}
\crefname{ex}{例}{例}

\newaliascnt{conj}{theoremcounter}
\newtheorem{conj}[conj]{予想}
\aliascntresetthe{conj}
\crefname{conj}{予想}{予想}

\newaliascnt{que}{theoremcounter}
\newtheorem{que}[que]{疑問}
\aliascntresetthe{que}
\crefname{que}{疑問}{疑問}

\newaliascnt{prob}{theoremcounter}
\newtheorem{prob}[prob]{問題}
\aliascntresetthe{prob}
\crefname{prob}{問題}{問題}

\newaliascnt{clm}{theoremcounter}
\newtheorem{clm}[clm]{主張}
\aliascntresetthe{clm}
\crefname{clm}{主張}{主張}

\newaliascnt{assump}{theoremcounter}
\newtheorem{assump}[assump]{仮定}
\aliascntresetthe{assump}
\crefname{assump}{仮定}{仮定}

\newaliascnt{obs}{theoremcounter}
\newtheorem{obs}[obs]{観察}
\aliascntresetthe{obs}
\crefname{obs}{観察}{観察}

\newaliascnt{notn}{theoremcounter}
\newtheorem{notn}[notn]{記法}
\aliascntresetthe{notn}
\crefname{notn}{記法}{記法}

\newtheorem*{notn*}{記法}

\newtheorem*{symb}{記号}

\newtheorem*{obs*}{観察}

\newaliascnt{exc}{exercisecounter}
\newtheorem{exc}[exc]{演習問題}
\aliascntresetthe{exc}
\crefname{exc}{演習問題}{演習問題}

\newtheorem*{exc*}{演習問題}

